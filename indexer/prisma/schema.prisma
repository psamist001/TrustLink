generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attestation {
  id          String   @id           // deterministic hash ID from the contract
  issuer      String
  subject     String
  claimType   String
  timestamp   BigInt
  expiration  BigInt?
  isRevoked   Boolean  @default(false)
  metadata    String?
  imported    Boolean  @default(false)
  bridged     Boolean  @default(false)
  sourceChain String?
  sourceTx    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([issuer])
  @@index([claimType])
  @@index([subject, claimType])
  @@index([timestamp])
}

model MultisigProposal {
  id              String   @id           // proposal ID from the contract
  subject         String
  proposer        String
  claimType       String
  threshold       Int
  signers         String[] // array of signer addresses that have co-signed
  signatureCount  Int      @default(1)
  finalized       Boolean  @default(false)
  expiresAt       BigInt
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subject])
  @@index([proposer])
  @@index([finalized])
  @@index([subject, finalized])
}

// Singleton row (id=1) tracking the last fully-processed ledger sequence.
model Checkpoint {
  id     Int @id @default(1)
  ledger Int
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Issuer {
  address      String   @id // issuer address
  name         String
  url          String?
  description  String?
  tier         String   @default("basic")
  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tier])
}
